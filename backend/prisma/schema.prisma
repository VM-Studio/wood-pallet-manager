generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ────────────────────────────────────────────
model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String
  apellido      String
  email         String     @unique
  passwordHash  String
  telefono      String?
  cuit          String?
  rol           RolUsuario
  activo        Boolean    @default(true)
  fechaCreacion DateTime   @default(now())
  fotoPerfil    String? // base64 data URL
  firma         String? // base64 data URL

  // Relaciones
  clientes             Cliente[]
  cotizaciones         Cotizacion[]
  ventas               Venta[]
  compras              Compra[]
  productos            Producto[]               @relation("ProductosPropietario")
  listaPrecios         ListaPrecio[]
  historialPrecios     HistorialPrecio[]
  movimientosStock     MovimientoStock[]
  logisticas           Logistica[]
  facturas             Factura[]
  pagos                PagoCobro[]
  notasCredito         NotaCredito[]
  pagosProveedores     PagoProveedor[]
  retirosParciales     RetiroParcial[]
  seguimientos         SeguimientoCotizacion[]
  solicitudesEnviadas  SolicitudLogistica[]     @relation("SolicitudSolicitante")
  solicitudesRecibidas SolicitudLogistica[]     @relation("SolicitudDestinatario")
  consultasLogistica   Logistica[]              @relation("ConsultasLogistica")
  devoluciones         Devolucion[]
  remitos              Remito[]
  plantillasEmail      PlantillaEmail[]
  campanasEnviadas     CampanaSeguimiento[]
  reglasAutomatizacion ReglaAutomatizacion[]
  verificacionesCodigo VerificacionCodigo[]
  retirosConfirmados   Retiro[]                 @relation("RetirosConfirmados")
  reenviosRetiro       HistorialReenvioRetiro[]

  @@map("usuarios")
}

enum RolUsuario {
  propietario_carlos
  propietario_juancruz
  admin
}

// ─── VERIFICACIONES DE CÓDIGO ────────────────────────────
model VerificacionCodigo {
  id        Int              @id @default(autoincrement())
  usuarioId Int?
  email     String? // para recuperación donde el usuario puede no existir
  codigo    String // 6 dígitos
  tipo      TipoVerificacion
  dato      String? // payload: nuevo email / nuevo teléfono
  canal     String? // 'email' | 'telefono'
  expiresAt DateTime
  usado     Boolean          @default(false)
  creadoAt  DateTime         @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("verificaciones_codigo")
}

enum TipoVerificacion {
  cambio_password
  cambio_email
  cambio_telefono
  recuperacion_password
}

// ─── CLIENTES ────────────────────────────────────────────
model Cliente {
  id                Int           @id @default(autoincrement())
  razonSocial       String
  cuit              String?
  nombreContacto    String?
  telefonoContacto  String?
  emailContacto     String?
  canalEntrada      CanalEntrada?
  usuarioAsignadoId Int
  direccionEntrega  String?
  localidad         String?
  esExportador      Boolean       @default(false)
  observaciones     String?
  fechaAlta         DateTime      @default(now())
  activo            Boolean       @default(true)

  // Relaciones
  usuarioAsignado      Usuario               @relation(fields: [usuarioAsignadoId], references: [id])
  cotizaciones         Cotizacion[]
  ventas               Venta[]
  facturas             Factura[]
  pagos                PagoCobro[]
  notasCredito         NotaCredito[]
  devoluciones         Devolucion[]
  remitos              Remito[]
  destinatariosCampana DestinatarioCampana[]

  @@map("clientes")
}

enum CanalEntrada {
  whatsapp
  formulario_web
  llamada
  recomendacion
  instagram
  email
  otro
}

// ─── PRODUCTOS ───────────────────────────────────────────
model Producto {
  id             Int             @id @default(autoincrement())
  nombre         String
  tipo           TipoPallet
  condicion      CondicionPallet
  propietarioId  Int
  dimensionLargo Int?
  dimensionAncho Int?
  cargaMaximaKg  Int?
  requiereSenasa Boolean         @default(false)
  descripcion    String?
  activo         Boolean         @default(true)

  // Relaciones
  propietario        Usuario             @relation("ProductosPropietario", fields: [propietarioId], references: [id])
  prodProveedores    ProductoProveedor[]
  listaPrecios       ListaPrecio[]
  historialPrecios   HistorialPrecio[]
  stocks             Stock[]
  detallesCotizacion DetalleCotizacion[]
  detallesVenta      DetalleVenta[]
  detallesCompra     DetalleCompra[]
  detallesDevolucion DetalleDevolucion[]

  @@map("productos")
}

enum TipoPallet {
  estandar
  reforzado
  liviano
  exportacion
  carton
  a_medida
  personalizado
}

enum CondicionPallet {
  nuevo
  seminuevo
  usado
}

// ─── PROVEEDORES ─────────────────────────────────────────
model Proveedor {
  id                  Int                   @id @default(autoincrement())
  nombreEmpresa       String
  nombreContacto      String
  telefono            String?
  email               String?
  tipoProducto        TipoProductoProveedor
  contactoExclusivoId Int?
  distanciaKm         Int?
  ubicacion           String?
  observaciones       String?
  activo              Boolean               @default(true)

  // Relaciones
  prodProveedores ProductoProveedor[]
  stocks          Stock[]
  compras         Compra[]
  pagos           PagoProveedor[]

  @@map("proveedores")
}

enum TipoProductoProveedor {
  seminuevo
  nuevo_medida
  ambos
}

// ─── PRODUCTO_PROVEEDOR ──────────────────────────────────
model ProductoProveedor {
  id                 Int      @id @default(autoincrement())
  proveedorId        Int
  productoId         Int
  precioCosto        Decimal  @db.Decimal(12, 2)
  fechaActualizacion DateTime @default(now())
  observaciones      String?

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@map("producto_proveedor")
}

// ─── LISTA DE PRECIOS ────────────────────────────────────
model ListaPrecio {
  id             Int       @id @default(autoincrement())
  productoId     Int
  precioUnitario Decimal   @db.Decimal(12, 2)
  margenPct      Decimal?  @db.Decimal(5, 2)
  cantMinima     Int
  cantMaxima     Int?
  bonificaFlete  Boolean   @default(false)
  vigentDesde    DateTime  @default(now())
  vigentHasta    DateTime?
  creadoPorId    Int
  observaciones  String?

  producto  Producto @relation(fields: [productoId], references: [id])
  creadoPor Usuario  @relation(fields: [creadoPorId], references: [id])

  @@map("lista_precios")
}

// ─── HISTORIAL DE PRECIOS ────────────────────────────────
model HistorialPrecio {
  id              Int      @id @default(autoincrement())
  productoId      Int
  precioAnterior  Decimal  @db.Decimal(12, 2)
  precioNuevo     Decimal  @db.Decimal(12, 2)
  motivo          String?
  fechaCambio     DateTime @default(now())
  registradoPorId Int

  producto      Producto @relation(fields: [productoId], references: [id])
  registradoPor Usuario  @relation(fields: [registradoPorId], references: [id])

  @@map("historial_precios")
}

// ─── STOCK ───────────────────────────────────────────────
model Stock {
  id                  Int      @id @default(autoincrement())
  productoId          Int
  proveedorId         Int
  cantidadDisponible  Int      @default(0)
  cantidadMinima      Int?
  cantidadDeudora     Int      @default(0)
  ultimaActualizacion DateTime @updatedAt
  observaciones       String?

  producto    Producto          @relation(fields: [productoId], references: [id])
  proveedor   Proveedor         @relation(fields: [proveedorId], references: [id])
  movimientos MovimientoStock[]

  @@unique([productoId, proveedorId])
  @@map("stock")
}

// ─── MOVIMIENTOS DE STOCK ────────────────────────────────
model MovimientoStock {
  id              Int              @id @default(autoincrement())
  stockId         Int
  tipoMovimiento  TipoMovimiento
  cantidad        Int
  motivo          MotivoMovimiento
  idReferencia    Int?
  fecha           DateTime         @default(now())
  registradoPorId Int

  stock         Stock   @relation(fields: [stockId], references: [id])
  registradoPor Usuario @relation(fields: [registradoPorId], references: [id])

  @@map("movimientos_stock")
}

enum TipoMovimiento {
  entrada
  salida
  ajuste
}

enum MotivoMovimiento {
  venta
  compra
  devolucion
  ajuste_manual
}

// ─── COTIZACIONES ────────────────────────────────────────
model Cotizacion {
  id                Int                   @id @default(autoincrement())
  clienteId         Int?
  usuarioId         Int
  fechaCotizacion   DateTime              @default(now())
  fechaVencimiento  DateTime?
  estado            EstadoCotizacion      @default(enviada)
  incluyeFlete      Boolean               @default(false)
  costoFlete        Decimal?              @db.Decimal(12, 2)
  fleteIncluido     Boolean               @default(true)
  requiereSenasa    Boolean               @default(false)
  costoSenasa       Decimal?              @db.Decimal(12, 2)
  totalSinIva       Decimal?              @db.Decimal(12, 2)
  totalConIva       Decimal?              @db.Decimal(12, 2)
  canalEnvio        CanalEnvioCotizacion?
  observaciones     String?
  esRapida          Boolean               @default(false)
  nombreProspecto   String?
  telefonoProspecto String?
  emailProspecto    String?

  cliente      Cliente?                @relation(fields: [clienteId], references: [id])
  usuario      Usuario                 @relation(fields: [usuarioId], references: [id])
  detalles     DetalleCotizacion[]
  venta        Venta?
  seguimientos SeguimientoCotizacion[]

  @@map("cotizaciones")
}

enum EstadoCotizacion {
  enviada
  en_seguimiento
  aceptada
  rechazada
  perdida
  vencida
}

enum CanalEnvioCotizacion {
  whatsapp
  email
}

// ─── DETALLE COTIZACION ──────────────────────────────────
model DetalleCotizacion {
  id             Int     @id @default(autoincrement())
  cotizacionId   Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)
  esAMedida      Boolean @default(false)

  cotizacion     Cotizacion            @relation(fields: [cotizacionId], references: [id])
  producto       Producto              @relation(fields: [productoId], references: [id])
  especificacion EspecificacionMedida?

  @@map("detalle_cotizacion")
}

// ─── ESPECIFICACIONES A MEDIDA ───────────────────────────
model EspecificacionMedida {
  id                   Int     @id @default(autoincrement())
  detalleCotizacionId  Int?    @unique
  detalleVentaId       Int?    @unique
  largoMm              Int?
  anchoMm              Int?
  altoMm               Int?
  cargaMaximaKg        Int?
  tipoMadera           String?
  observacionesCliente String?
  medidas              Json?

  detalleVenta      DetalleVenta?      @relation(fields: [detalleVentaId], references: [id])
  detalleCotizacion DetalleCotizacion? @relation(fields: [detalleCotizacionId], references: [id])

  @@map("especificaciones_medida")
}

// ─── SEGUIMIENTO COTIZACION ──────────────────────────────
model SeguimientoCotizacion {
  id              Int                  @id @default(autoincrement())
  cotizacionId    Int
  usuarioId       Int
  fechaContacto   DateTime             @default(now())
  tipoContacto    TipoContacto
  resultado       ResultadoSeguimiento
  observaciones   String?
  proximoContacto DateTime?

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id])
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("seguimiento_cotizacion")
}

enum TipoContacto {
  whatsapp
  llamada
  email
  presencial
}

enum ResultadoSeguimiento {
  sin_respuesta
  interesado
  no_interesado
  cerrado
  reprogramado
}

// ─── VENTAS ──────────────────────────────────────────────
model Venta {
  id                Int            @id @default(autoincrement())
  cotizacionId      Int?           @unique
  clienteId         Int
  usuarioId         Int
  fechaVenta        DateTime       @default(now())
  estadoPedido      EstadoPedido   @default(confirmado)
  tipoEntrega       TipoEntrega
  requiereSenasa    Boolean        @default(false)
  fechaEstimEntrega DateTime?
  fechaEntregaReal  DateTime?
  fechaRetiro       DateTime?
  lugarEntrega      String?
  totalSinIva       Decimal?       @db.Decimal(12, 2)
  totalConIva       Decimal?       @db.Decimal(12, 2)
  costoFlete        Decimal?       @db.Decimal(12, 2)
  metodoPago        MetodoPago?
  cuentaDestino     String?
  modalidadPago     ModalidadPago?
  observaciones     String?
  origenStock       String?        @default("stock_propio")

  cotizacion           Cotizacion?          @relation(fields: [cotizacionId], references: [id])
  cliente              Cliente              @relation(fields: [clienteId], references: [id])
  usuario              Usuario              @relation(fields: [usuarioId], references: [id])
  detalles             DetalleVenta[]
  logistica            Logistica?
  retiroGalpon         Retiro?
  facturas             Factura[]
  compras              Compra[]
  solicitudesLogistica SolicitudLogistica[]
  devoluciones         Devolucion[]
  remito               Remito?

  @@map("ventas")
}

enum EstadoPedido {
  confirmado
  en_preparacion
  listo_para_envio
  en_transito
  entregado
  entregado_parcial
  cancelado
}

enum TipoEntrega {
  retira_cliente
  envio_woodpallet
}

// ─── DETALLE VENTA ───────────────────────────────────────
model DetalleVenta {
  id                Int     @id @default(autoincrement())
  ventaId           Int
  productoId        Int
  cantidadPedida    Int
  cantidadEntregada Int     @default(0)
  precioUnitario    Decimal @db.Decimal(12, 2)
  subtotal          Decimal @db.Decimal(12, 2)
  observaciones     String?

  venta          Venta                 @relation(fields: [ventaId], references: [id])
  producto       Producto              @relation(fields: [productoId], references: [id])
  especificacion EspecificacionMedida?
  retiros        RetiroParcial[]
  devoluciones   DetalleDevolucion[]

  @@map("detalle_venta")
}

// ─── RETIROS DE GALPÓN ───────────────────────────────────
model Retiro {
  id                 Int          @id @default(autoincrement())
  ventaId            Int          @unique
  codigoRetiro       String       @unique
  estadoRetiro       EstadoRetiro @default(pendiente)
  galpon             String?
  horaEstimadaRetiro DateTime?
  confirmadoPorId    Int?
  fechaConfirmacion  DateTime?
  observacionesConf  String?
  motivoCancelacion  String?
  creadoEn           DateTime     @default(now())

  venta             Venta                    @relation(fields: [ventaId], references: [id])
  confirmadoPor     Usuario?                 @relation("RetirosConfirmados", fields: [confirmadoPorId], references: [id])
  historialReenvios HistorialReenvioRetiro[]

  @@map("retiros_galpon")
}

enum EstadoRetiro {
  pendiente
  confirmado
  completado
  cancelado
}

model HistorialReenvioRetiro {
  id              Int      @id @default(autoincrement())
  retiroId        Int
  emailEnviado    String?
  telefonoEnviado String?
  enviadoPorId    Int
  creadoEn        DateTime @default(now())

  retiro     Retiro  @relation(fields: [retiroId], references: [id])
  enviadoPor Usuario @relation(fields: [enviadoPorId], references: [id])

  @@map("historial_reenvio_retiro")
}

// ─── RETIROS PARCIALES ───────────────────────────────────
model RetiroParcial {
  id               Int      @id @default(autoincrement())
  detalleVentaId   Int
  fechaRetiro      DateTime @default(now())
  cantidadRetirada Int
  registradoPorId  Int

  detalleVenta  DetalleVenta @relation(fields: [detalleVentaId], references: [id])
  registradoPor Usuario      @relation(fields: [registradoPorId], references: [id])

  @@map("retiros_parciales")
}

// ─── COMPRAS ─────────────────────────────────────────────
model Compra {
  id             Int          @id @default(autoincrement())
  proveedorId    Int
  usuarioId      Int
  ventaId        Int?
  fechaCompra    DateTime     @default(now())
  estado         EstadoCompra @default(pendiente_pago)
  tipoCompra     TipoCompra   @default(reventa_inmediata)
  total          Decimal?     @db.Decimal(12, 2)
  nroRemito      String?
  observaciones  String?
  saldoDeudor    Boolean      @default(true)
  fechaPago      DateTime?
  metodoPago     MetodoPago?
  cuentaDestino  String?
  nroComprobante String?

  proveedor Proveedor       @relation(fields: [proveedorId], references: [id])
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  venta     Venta?          @relation(fields: [ventaId], references: [id])
  detalles  DetalleCompra[]
  pagos     PagoProveedor[]

  @@map("compras")
}

enum EstadoCompra {
  pendiente_pago
  pagada
  cancelada
}

enum TipoCompra {
  reventa_inmediata
  stock_propio
}

// ─── DETALLE COMPRA ──────────────────────────────────────
model DetalleCompra {
  id              Int     @id @default(autoincrement())
  compraId        Int
  productoId      Int
  cantidad        Int
  precioCostoUnit Decimal @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  compra   Compra   @relation(fields: [compraId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_compra")
}

// ─── LOGISTICA ───────────────────────────────────────────
model Logistica {
  id                  Int            @id @default(autoincrement())
  ventaId             Int            @unique
  nombreTransportista String
  telefonoTransp      String?
  fechaRetiroGalpon   DateTime?
  horaRetiro          DateTime?
  horaEstimadaEntrega DateTime?
  horaEntregaReal     DateTime?
  estadoEntrega       EstadoEntrega  @default(pendiente)
  confTransportista   Boolean        @default(false)
  confCliente         Boolean        @default(false)
  costoFlete          Decimal?       @db.Decimal(12, 2)
  registradoPorId     Int
  observaciones       String?
  lugarEntrega        String?
  estadoConsulta      EstadoConsulta @default(no_aplica)
  fechaConsulta       DateTime?
  consultadaPorId     Int?

  venta         Venta    @relation(fields: [ventaId], references: [id])
  registradoPor Usuario  @relation(fields: [registradoPorId], references: [id])
  consultadaPor Usuario? @relation("ConsultasLogistica", fields: [consultadaPorId], references: [id])

  @@map("logistica")
}

enum EstadoEntrega {
  pendiente
  en_camino
  entregado
  con_problema
}

// ─── FACTURAS ────────────────────────────────────────────
model Factura {
  id               Int         @id @default(autoincrement())
  ventaId          Int
  clienteId        Int
  usuarioId        Int
  tipoFactura      TipoFactura @default(A)
  nroFactura       String?
  esSinFactura     Boolean     @default(false)
  fechaEmision     DateTime    @default(now())
  fechaVencimiento DateTime?
  totalNeto        Decimal     @db.Decimal(12, 2)
  iva              Decimal     @db.Decimal(12, 2)
  totalConIva      Decimal     @db.Decimal(12, 2)
  estadoCobro      EstadoCobro @default(pendiente)
  modalidadPago    String?
  medioPago        String?
  metodoPago       MetodoPago?
  cuentaDestino    String?
  observaciones    String?

  venta        Venta         @relation(fields: [ventaId], references: [id])
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  pagos        PagoCobro[]
  notasCredito NotaCredito[]

  @@map("facturas")
}

enum TipoFactura {
  A
}

enum EstadoCobro {
  pendiente
  cobrada_parcial
  cobrada_total
  vencida
  incobrable
}

// ─── PAGOS / COBROS ──────────────────────────────────────
model PagoCobro {
  id              Int       @id @default(autoincrement())
  facturaId       Int
  clienteId       Int
  fechaPago       DateTime  @default(now())
  monto           Decimal   @db.Decimal(12, 2)
  medioPago       MedioPago
  nroComprobante  String?
  esAdelanto      Boolean   @default(false)
  registradoPorId Int
  observaciones   String?

  factura       Factura @relation(fields: [facturaId], references: [id])
  cliente       Cliente @relation(fields: [clienteId], references: [id])
  registradoPor Usuario @relation(fields: [registradoPorId], references: [id])

  @@map("pagos_cobros")
}

enum MedioPago {
  transferencia
  e_check
  efectivo
}

// ─── NOTAS DE CREDITO ────────────────────────────────────
model NotaCredito {
  id           Int      @id @default(autoincrement())
  facturaId    Int
  clienteId    Int
  usuarioId    Int
  fechaEmision DateTime @default(now())
  nroNota      String?
  monto        Decimal  @db.Decimal(12, 2)
  motivo       String

  factura Factura @relation(fields: [facturaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("notas_credito")
}

// ─── PAGOS A PROVEEDORES ─────────────────────────────────
model PagoProveedor {
  id              Int       @id @default(autoincrement())
  compraId        Int
  proveedorId     Int
  fechaPago       DateTime  @default(now())
  monto           Decimal   @db.Decimal(12, 2)
  medioPago       MedioPago
  nroComprobante  String?
  registradoPorId Int
  observaciones   String?

  compra        Compra    @relation(fields: [compraId], references: [id])
  proveedor     Proveedor @relation(fields: [proveedorId], references: [id])
  registradoPor Usuario   @relation(fields: [registradoPorId], references: [id])

  @@map("pagos_proveedores")
}

// ─── SOLICITUDES DE LOGISTICA ────────────────────────────
model SolicitudLogistica {
  id               Int                      @id @default(autoincrement())
  ventaId          Int?
  solicitanteId    Int
  destinatarioId   Int
  fechaSolicitud   DateTime                 @default(now())
  fechaEntrega     DateTime?
  cantidadUnidades Int?
  ubicacionEntrega String?
  notas            String?
  estado           EstadoSolicitudLogistica @default(pendiente)
  fechaRespuesta   DateTime?
  notasRespuesta   String?

  venta        Venta?  @relation(fields: [ventaId], references: [id])
  solicitante  Usuario @relation("SolicitudSolicitante", fields: [solicitanteId], references: [id])
  destinatario Usuario @relation("SolicitudDestinatario", fields: [destinatarioId], references: [id])

  @@map("solicitudes_logistica")
}

enum EstadoSolicitudLogistica {
  pendiente
  aceptada
  rechazada
}

enum MetodoPago {
  transferencia
  e_check
  efectivo
}

enum ModalidadPago {
  adelantado
  contra_entrega
  por_partes
}

enum EstadoConsulta {
  no_aplica
  pendiente_consulta
  consultada
  aceptada
  rechazada
}

// ─── DEVOLUCIONES ────────────────────────────────────────
model Devolucion {
  id                           Int                @id @default(autoincrement())
  ventaId                      Int
  clienteId                    Int
  usuarioId                    Int
  fechaSolicitud               DateTime           @default(now())
  tipoCaso                     TipoCasoDevolucion
  estado                       EstadoDevolucion   @default(pendiente)
  devuelveFlete                Boolean            @default(false)
  devuelveSenasa               Boolean            @default(false)
  montoPallets                 Decimal            @db.Decimal(12, 2)
  montoFlete                   Decimal?           @db.Decimal(12, 2)
  montoSenasa                  Decimal?           @db.Decimal(12, 2)
  montoTotal                   Decimal            @db.Decimal(12, 2)
  requiereConfirmacionDeposito Boolean            @default(false)
  depositoConfirmo             Boolean            @default(false)
  fechaConfirmacionDeposito    DateTime?
  stockRestaurado              Boolean            @default(false)
  compensaEnSiguientePedido    Boolean            @default(false)
  metodoPago                   MetodoPago?
  cuentaDestino                String?
  observaciones                String?

  venta    Venta               @relation(fields: [ventaId], references: [id])
  cliente  Cliente             @relation(fields: [clienteId], references: [id])
  usuario  Usuario             @relation(fields: [usuarioId], references: [id])
  detalles DetalleDevolucion[]

  @@map("devoluciones")
}

model DetalleDevolucion {
  id               Int     @id @default(autoincrement())
  devolucionId     Int
  detalleVentaId   Int?
  productoId       Int
  cantidadDevuelta Int
  precioUnitario   Decimal @db.Decimal(12, 2)
  subtotal         Decimal @db.Decimal(12, 2)

  devolucion   Devolucion    @relation(fields: [devolucionId], references: [id])
  detalleVenta DetalleVenta? @relation(fields: [detalleVentaId], references: [id])
  producto     Producto      @relation(fields: [productoId], references: [id])

  @@map("detalle_devolucion")
}

enum TipoCasoDevolucion {
  pallet_danado
  cliente_no_quiere
  devolucion_parcial
  cancelacion_anticipada
}

enum EstadoDevolucion {
  pendiente
  esperando_confirmacion_deposito
  confirmada
  procesada
  cancelada
}

// ─── REMITOS ─────────────────────────────────────────────
model Remito {
  id                    Int          @id @default(autoincrement())
  numeroRemito          String?
  ventaId               Int          @unique
  clienteId             Int
  usuarioId             Int
  fechaEmision          DateTime     @default(now())
  fechaEntrega          DateTime?
  estado                EstadoRemito @default(pendiente_firma_propietario)
  firmaPropietario      String?      @db.Text
  fechaFirmaPropietario DateTime?
  firmaCliente          String?      @db.Text
  fechaFirmaCliente     DateTime?
  tokenFirma            String       @unique @default(uuid())
  emailEnviado          Boolean      @default(false)
  fechaEmailEnviado     DateTime?
  observaciones         String?

  venta   Venta   @relation(fields: [ventaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("remitos")
}

enum EstadoRemito {
  pendiente_firma_propietario
  enviado_a_cliente
  firmado_por_cliente
  completado
  cancelado
}

// ─── EMAIL MARKETING / SEGUIMIENTOS ──────────────────────

model PlantillaEmail {
  id          Int      @id @default(autoincrement())
  nombre      String
  asunto      String
  bloques     Json // array de bloques de contenido
  creadaPorId Int
  creadaEn    DateTime @default(now())
  activa      Boolean  @default(true)

  creadaPor            Usuario               @relation(fields: [creadaPorId], references: [id])
  campanas             CampanaSeguimiento[]
  reglasAutomatizacion ReglaAutomatizacion[]

  @@map("plantillas_email")
}

model CampanaSeguimiento {
  id                 Int      @id @default(autoincrement())
  nombre             String
  asunto             String
  segmento           String // 'activos' | 'cotizacion_sin_respuesta' | 'cotizacion_rechazada' | 'sin_actividad' | 'todos' | 'manual'
  diasCondicion      Int? // para segmentos con umbral de días
  bloques            Json // snapshot de bloques al momento del envío
  plantillaId        Int?
  enviadaPorId       Int
  enviadaEn          DateTime @default(now())
  totalDestinatarios Int      @default(0)
  estado             String   @default("enviado") // 'borrador' | 'enviado'

  enviadaPor    Usuario               @relation(fields: [enviadaPorId], references: [id])
  plantilla     PlantillaEmail?       @relation(fields: [plantillaId], references: [id])
  destinatarios DestinatarioCampana[]

  @@map("campanas_seguimiento")
}

model DestinatarioCampana {
  id        Int       @id @default(autoincrement())
  campanaId Int
  clienteId Int
  email     String
  enviado   Boolean   @default(false)
  error     String?
  enviadoEn DateTime?

  campana CampanaSeguimiento @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  cliente Cliente            @relation(fields: [clienteId], references: [id])

  @@map("destinatarios_campana")
}

model ReglaAutomatizacion {
  id            Int      @id @default(autoincrement())
  nombre        String
  activa        Boolean  @default(true)
  evento        String // 'cotizacion_sin_respuesta' | 'sin_actividad'
  diasCondicion Int // días sin respuesta / inactividad
  plantillaId   Int
  asunto        String
  creadaPorId   Int
  creadaEn      DateTime @default(now())

  plantilla PlantillaEmail @relation(fields: [plantillaId], references: [id])
  creadaPor Usuario        @relation(fields: [creadaPorId], references: [id])

  @@map("reglas_automatizacion")
}
